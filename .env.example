# SARAH Eulen-Video-Worker — Umgebung (NUR auf der Worker-Box, nie committen).
# Kopieren nach ".env" (systemd lädt sie via EnvironmentFile) und ausfüllen.

# Supabase-Projekt tatbddeqffquxltvpmbs
SUPABASE_URL=https://tatbddeqffquxltvpmbs.supabase.co

# Service-Role-Key (Supabase Dashboard -> Project Settings -> API -> service_role).
# Umgeht RLS bewusst; darf NUR hier auf der Box liegen, niemals im SARAH-Client.
SUPABASE_SERVICE_ROLE_KEY=

# Optional:
# POLL_MS=15000            # Abfrage-Intervall der Warteschlange (ms)
# LOGIN_WARTE_MS=300000    # Wartezeit nach "Login abgelaufen" (ms)
# HIGGSFIELD_BIN=higgsfield  # Pfad zur CLI, falls nicht auf PATH

# --- X/TIKTOK-ENGAGEMENT-WORKER (engagement-worker.mjs) ---------------------
# Für die KI-Antwortentwürfe im Holding-Ton (dieselbe Anthropic-Key wie SARAH):
ANTHROPIC_API_KEY=
# Optional:
# ENGAGEMENT_MODELL=claude-sonnet-4-6
# ENGAGEMENT_STATE_DIR=/home/ubuntu/worker/state   # wo x-state.json / tiktok-state.json liegen
# ENGAGEMENT_DRYRUN=1                               # erzwingt Probe-Modus (klickt nichts)
